    <div>
        <label>앨범 사진 추가</label>
        <div style="width:150px;height:150px;border:1px solid #ccc;display:flex;align-items:center;justify-content:center;">
            <img id="preview" src="~/Content/photo-icon.png" style="max-width:100%;max-height:100%;" />
        </div>
        <input type="file" name="AlbumImage" id="AlbumImage" accept="image/*" style="margin-top:5px;" />
    </div>
    <div>
        <label for="Artist">아티스트</label>
        <input type="text" name="Artist" id="Artist" value="@Request["Artist"]" />
    </div>
    <div>
        <label for="AlbumTitle">앨범명</label>
        <input type="text" name="AlbumTitle" id="AlbumTitle" value="@Request["AlbumTitle"]" />
    </div>
    <div>
        <label for="Genre">장르</label>
        <input type="text" name="Genre" id="Genre" value="@Request["Genre"]" />
    </div>
    <div>
        <label for="Label">레이블</label>
        <input type="text" name="Label" id="Label" value="@Request["Label"]" />
    </div>
    <div>
        <label for="ReleaseDate">발매일</label>
        <input type="text" name="ReleaseDate" id="ReleaseDate" value="@Request["ReleaseDate"]" placeholder="YYYY-MM-DD" />
    </div>
    <input type="hidden" name="AddedBy" value="@Session["Username"]" />
    <input type="hidden" name="ModifiedBy" value="@Session["Username"]" />
    <div id="Message" style="color:@ViewBag.MessageColor;">@ViewBag.Message</div>
    <div>
        <button type="submit" id="RegisterButton" @(isSuccess ? "disabled" : "")>등록</button>
        <button type="button" id="ResetButton">초기화</button>
    </div>
}
@section Scripts {
    <script src="~/Scripts/AddAlbum.js"></script>
}
