
@model MediaDB.Models.AlbumService.AlbumDetailInfo

@{
    ViewBag.Title = "Album Detail";
}

<div class="container mt-4 mb-5">
    <div class="row g-4">
        <div class="col-4">
            @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.AlbumTitle" class="img-fluid rounded shadow-sm w-100" />
            }
            else
            {
                <div class="border rounded d-flex align-items-center justify-content-center" style="height:420px;">
                    <span class="text-muted">이미지 없음</span>
                </div>
            }
        </div>

        <div class="col-8">
            <h2 class="fw-bold mb-2">@Model.AlbumTitle</h2>
            <h5 class="text-muted mb-4">@Model.Artist</h5>

            <table class="table table-striped table-bordered">
                <tbody>
                    @if (!string.IsNullOrWhiteSpace(Model.Genre))
                    {
                        <tr>
                            <th style="width:180px;">Genre</th>
                            <td>@Model.Genre</td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Label))
                    {
                        <tr>
                            <th>Label</th>
                            <td>@Model.Label</td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ReleaseDate))
                    {
                        <tr>
                            <th>Release date</th>
                            <td>@Model.ReleaseDate</td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.AddedBy))
                    {
                        <tr>
                            <th>Added by</th>
                            <td>@Model.AddedBy</td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ModifiedBy))
                    {
                        <tr>
                            <th>Modified by</th>
                            <td>@Model.ModifiedBy</td>
                        </tr>
                    }
                    @if (Model.CreatedAt.HasValue)
                    {
                        <tr>
                            <th>Created at</th>
                            <td>@Model.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Back to list</a>
        </div>
    </div>
</div>
