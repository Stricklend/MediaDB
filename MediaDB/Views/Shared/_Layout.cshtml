<!DOCTYPE html>
<html>
<head>
@{
    var isAccountPage = ViewBag.IsAccountPage != null && (bool)ViewBag.IsAccountPage;
    var hasUserSession = Session["Username"] != null || Session["UserId"] != null || Session["user_id"] != null;
    var displayName = Session["Username"] as string ?? Session["UserId"] as string ?? Session["user_id"] as string;
    var currentAction = Convert.ToString(ViewContext.RouteData.Values["action"]);
    var isLoginPage = isAccountPage && string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase);
    var isRegisterPage = isAccountPage && string.Equals(currentAction, "Register", StringComparison.OrdinalIgnoreCase);
    var shellClass = isAccountPage
        ? "auth-page " + (isLoginPage ? "auth-page-login" : isRegisterPage ? "auth-page-register" : string.Empty)
        : "site-page";
}
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediaDB</title>
    @Styles.Render("~/Content/css")
    <link rel="stylesheet" href="~/Content/account-auth.css" />
    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("styles", required: false)
</head>
<body class="site-layout@(isAccountPage ? " auth-layout" : string.Empty)">
    <div class="site-shell @shellClass">
        <nav class="auth-topbar">
            <div class="container-xxl auth-topbar__inner">
                <div class="auth-topbar__brand-group">
                    <a class="auth-topbar__brand" href="@Url.Action("Index", "Home")">MediaDB</a>
                    <div class="auth-topbar__nav">
                        <a class="auth-topbar__nav-link" href="@Url.Action("Index", "Home")">Main</a>
                        <a class="auth-topbar__nav-link" href="#">Music</a>
                        <!-- <a class="auth-topbar__nav-link" href="#">Games</a>
                        <a class="auth-topbar__nav-link" href="#">Movies</a>
                        <a class="auth-topbar__nav-link" href="#">TV</a> -->
                    </div>
                </div>
                <div class="auth-topbar__actions">
                    @if (!hasUserSession)
                    {
                        <a class="auth-topbar__action @(isLoginPage ? "auth-topbar__action--filled is-current" : "auth-topbar__action--ghost")" href="@Url.Action("Login", "Account")">Login</a>
                        <a class="auth-topbar__action @(isRegisterPage ? "auth-topbar__action--filled is-current" : "auth-topbar__action--ghost")" href="@Url.Action("Register", "Account")">Register</a>
                    }
                    else
                    {
                        <span class="auth-topbar__user">@displayName</span>
                        <form method="post" action="@Url.Action("Logout", "Account")" class="auth-topbar__form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="auth-topbar__action auth-topbar__action--ghost auth-topbar__button">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </nav>

        @if (isAccountPage)
        {
            @RenderBody()
        }
        else
        {
            <main class="site-main">
                <div class="container body-content site-main__content">
                    @RenderBody()
                </div>
            </main>
        }

        <footer class="auth-footer">
            <div class="container-xxl auth-footer__inner">
                <div class="auth-footer__brand">
                    <span class="auth-footer__title">MediaDB</span>
                    <span class="auth-footer__caption">2026 integrated database archive</span>
                </div>
                <div class="auth-footer__links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Archive Guidelines</a>
                    <a href="#">API Access</a>
                </div>
            </div>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @if (IsSectionDefined("scripts"))
    {
        @RenderSection("scripts", required: false)
    }
    else if (IsSectionDefined("Scripts"))
    {
        @RenderSection("Scripts", required: false)
    }
</body>
</html>
