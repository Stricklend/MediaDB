@{
    ViewBag.Title = "ШИПјАЁРд";
}

<h2>ШИПјАЁРд</h2>

@using (Html.BeginForm("Register", "Account", FormMethod.Post))
{
    <div>
        <label for="Username">Username:</label>
        @Html.TextBox("Username", null, new { id = "Username" })
    </div>
    <div>
        <label for="Password">Password:</label>
        @Html.Password("Password", null, new { id = "Password" })
    </div>
    <div>
        <label for="ConfirmPassword">Password ШЎРЮ:</label>
        @Html.Password("ConfirmPassword", null, new { id = "ConfirmPassword" })
    </div>
    <div id="Message" style="color: red;"></div>
    <div>
        <button type="submit" id="RegisterButton">ШИПјАЁРд</button>
        @Html.ActionLink("ЗЮБзРЮ", "Login", "Account") |
        @Html.ActionLink("ИоРЮШ­Ищ", "Index", "Home")
    </div>
}

@section Scripts {
    <script src="~/Scripts/Register.js"></script>
}

